# انسخ هذا الملف إلى .env واملأ القيم — لا تضع أي مفتاح حقيقي في .env.example

PORT=3001

# مفتاح Gemini API — يُستخدم لكل من الـ embeddings ونموذج الدردشة
GEMINI_API_KEY=

# Pinecone (مخزن المتجهات)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# وضع المحاكاة (Mock) للتطوير المحلي فقط:
# true  = إرجاع بيانات وهمية جاهزة دون استدعاء Gemini أو Pinecone إطلاقًا (لتوفير حصة Gemini المجانية اليومية أثناء تطوير الواجهة)
# false = المسار الحقيقي الكامل (RAG فعلي) — هذا هو الوضع الافتراضي إذا تُرك المتغير فارغًا
USE_MOCK=false
